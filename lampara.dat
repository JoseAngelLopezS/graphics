v 24 0.45 3.30 -0.35 eje_2
v 25 1.15 3.30 -0.35 eje_2
v 26 1.15 3.30 0.35 eje_2
v 27 0.45 3.30 0.35 eje_2
v 28 0.45 3.90 -0.35 eje_2
v 29 1.15 3.90 -0.35 eje_2
v 30 1.15 3.90 0.35 eje_2
v 31 0.45 3.90 0.35 eje_2
