# lampara.dat
# Proyecto final: Modelo 3D de una lampara de escritorio articulada
# Formato:
#   v id x y z pieza        -> vertice del modelo
#   e id1 id2 pieza         -> arista que une dos vertices
#   mov pieza eje px py pz min max paso descripcion -> movimiento sugerido
#
# Piezas principales:
#   base: pieza fija
#   eje_1: union entre base y brazo inferior
#   brazo_inferior: gira sobre eje_1
#   eje_2: union entre brazo inferior y brazo superior
#   brazo_superior: gira sobre eje_2
#   cabeza: gira sobre el extremo del brazo superior
#   foco: parte frontal de la cabeza
#

v 0 -2.00 0.00 -1.00 base
v 1 2.00 0.00 -1.00 base
v 2 2.00 0.00 1.00 base
v 3 -2.00 0.00 1.00 base
v 4 -2.00 0.40 -1.00 base
v 5 2.00 0.40 -1.00 base
v 6 2.00 0.40 1.00 base
v 7 -2.00 0.40 1.00 base
e 0 1 base
e 1 2 base
e 2 3 base
e 3 0 base
e 4 5 base
e 5 6 base
e 6 7 base
e 7 4 base
e 0 4 base
e 1 5 base
e 2 6 base
e 3 7 base

v 8 -0.40 0.40 -0.40 eje_1
v 9 0.40 0.40 -0.40 eje_1
v 10 0.40 0.40 0.40 eje_1
v 11 -0.40 0.40 0.40 eje_1
v 12 -0.40 1.00 -0.40 eje_1
v 13 0.40 1.00 -0.40 eje_1
v 14 0.40 1.00 0.40 eje_1
v 15 -0.40 1.00 0.40 eje_1
e 8 9 eje_1
e 9 10 eje_1
e 10 11 eje_1
e 11 8 eje_1
e 12 13 eje_1
e 13 14 eje_1
e 14 15 eje_1
e 15 12 eje_1
e 8 12 eje_1
e 9 13 eje_1
e 10 14 eje_1
e 11 15 eje_1

v 16 -0.15 1.00 -0.15 brazo_inferior
v 17 0.15 1.00 -0.15 brazo_inferior
v 18 0.15 1.00 0.15 brazo_inferior
v 19 -0.15 1.00 0.15 brazo_inferior
v 20 0.65 3.60 -0.15 brazo_inferior
v 21 0.95 3.60 -0.15 brazo_inferior
v 22 0.95 3.60 0.15 brazo_inferior
v 23 0.65 3.60 0.15 brazo_inferior
e 16 17 brazo_inferior
