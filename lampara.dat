# Movimientos sugeridos para el menu 'Mover piezas'
mov brazo_inferior z 0.00 1.00 0.00 -35 45 5 Brazo_inferior_arriba_abajo
mov brazo_superior z 0.80 3.60 0.00 -45 45 5 Brazo_superior_arriba_abajo
mov cabeza z 2.80 4.60 0.00 -30 30 5 Cabeza_izquierda_derecha
mov lampara y 0.00 0.00 0.00 -90 90 10 Girar_modelo_completo

# Fin del archivo
